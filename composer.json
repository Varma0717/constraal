{
    "name": "constraal/website",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0",
        "barryvdh/laravel-dompdf": "^3.1"
    },
    "require-dev": {
        "laravel/tinker": "^2.8"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ]
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {}
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "filament/filament",
                "livewire/livewire",
                "blade-ui-kit/blade-icons",
                "spatie/laravel-package-tools",
                "filament/actions",
                "filament/forms",
                "filament/infolists",
                "filament/notifications",
                "filament/support",
                "filament/tables",
                "filament/widgets",
                "danharrin/livewire-rate-limiting"
            ]
        }
    }
}